{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hostwright.dev/schemas/hostwright-yaml.schema.json",
  "title": "Hostwright Manifest",
  "description": "Hostwright manifest shape. The Swift parser supports a restricted Hostwright subset, not general YAML.",
  "type": "object",
  "required": ["version", "project", "services"],
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "required": ["imagePolicy"],
        "properties": {
          "imagePolicy": {
            "const": "require-digest"
          }
        }
      },
      "then": {
        "properties": {
          "services": {
            "additionalProperties": {
              "allOf": [
                {
                  "$ref": "#/$defs/service"
                },
                {
                  "properties": {
                    "image": {
                      "pattern": "^(?!-)(?!.*://)[^@\\s]+@sha256:[a-f0-9]{64}$"
                    }
                  }
                }
              ]
            }
          }
        }
      }
    }
  ],
  "properties": {
    "version": {
      "type": "integer",
      "const": 2,
      "description": "Required Manifest v2 contract for Hostwright v0.0.2. Use hostwright migrate preview for legacy v1 manifests."
    },
    "project": {
      "type": "string",
      "pattern": "^[a-z0-9]([a-z0-9-]{0,61}[a-z0-9])?$"
    },
    "imagePolicy": {
      "enum": ["allow-tags", "require-digest"],
      "description": "Optional image-reference policy. The default allow-tags preserves tag-based alpha manifests; require-digest rejects mutable tag-only image references."
    },
    "services": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/service"
      }
    }
  },
  "$defs": {
    "service": {
      "type": "object",
      "required": ["image"],
      "additionalProperties": false,
      "properties": {
        "image": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!-)(?!.*://)(?:[^@\\s]+|[^@\\s]+@sha256:[a-f0-9]{64})$"
        },
        "command": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[^-].*$"
          }
        },
        "env": {
          "type": "object",
          "propertyNames": {
            "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "secretEnv": {
          "type": "object",
          "propertyNames": {
            "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
          },
          "additionalProperties": {
            "type": "string",
            "pattern": "^keychain://[A-Za-z0-9._:@-]+/[A-Za-z0-9._:@-]+$"
          }
        },
        "ports": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[0-9]{1,5}:[0-9]{1,5}$"
          }
        },
        "volumes": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^(?!/+(?:\\./*)*:)(?![^:]*(?:^|/)\\.\\.(?:/|:)).+:/[^:]+(:ro|:rw)?$"
          }
        },
        "health": {
          "$ref": "#/$defs/health"
        },
        "restart": {
          "$ref": "#/$defs/restart"
        }
      }
    },
    "health": {
      "type": "object",
      "required": ["command"],
      "additionalProperties": false,
      "properties": {
        "command": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "interval": {
          "type": "string",
          "pattern": "^[1-9][0-9]*s$"
        }
      }
    },
    "restart": {
      "type": "object",
      "required": ["policy"],
      "additionalProperties": false,
      "properties": {
        "policy": {
          "enum": ["no", "on-failure", "unless-stopped"]
        }
      }
    }
  }
}
