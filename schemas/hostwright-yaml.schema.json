{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hostwright.dev/schemas/hostwright-yaml.schema.json",
  "title": "Hostwright Manifest v2",
  "description": "Strict, bounded Hostwright Manifest v2 workload contract.",
  "type": "object",
  "required": ["version", "project", "services"],
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "imagePolicy": {
            "const": "require-digest"
          }
        },
        "required": ["imagePolicy"]
      },
      "then": {
        "properties": {
          "services": {
            "additionalProperties": {
              "allOf": [
                {
                  "$ref": "#/$defs/service"
                },
                {
                  "properties": {
                    "image": {
                      "pattern": "^(?!-)(?!.*://)[^@\\s]+@sha256:[a-f0-9]{64}$"
                    }
                  }
                }
              ]
            }
          }
        }
      }
    }
  ],
  "properties": {
    "version": {
      "type": "integer",
      "const": 2
    },
    "project": {
      "$ref": "#/$defs/name"
    },
    "imagePolicy": {
      "enum": ["allow-tags", "require-digest"]
    },
    "services": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "$ref": "#/$defs/name"
      },
      "additionalProperties": {
        "$ref": "#/$defs/service"
      }
    }
  },
  "$defs": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9]([a-z0-9-]{0,61}[a-z0-9])?$"
    },
    "size": {
      "type": "string",
      "pattern": "^[1-9][0-9]*(B|KiB|MiB|GiB|TiB)$"
    },
    "duration": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)s$"
    },
    "stringArray": {
      "type": "array",
      "maxItems": 1024,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 16384
      }
    },
    "service": {
      "type": "object",
      "required": ["image"],
      "additionalProperties": false,
      "properties": {
        "image": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!-)(?!.*://)(?:[^@\\s]+|[^@\\s]+@sha256:[a-f0-9]{64})$"
        },
        "replicas": {
          "type": "integer",
          "minimum": 1,
          "maximum": 256,
          "default": 1
        },
        "platform": {
          "$ref": "#/$defs/platform"
        },
        "resources": {
          "$ref": "#/$defs/resources"
        },
        "user": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4294967295
        },
        "group": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4294967295
        },
        "workdir": {
          "type": "string",
          "pattern": "^/(?!.*(?:^|/)\\.\\.?/)(?!.*//).*$"
        },
        "entrypoint": {
          "$ref": "#/$defs/stringArray"
        },
        "command": {
          "$ref": "#/$defs/stringArray"
        },
        "init": {
          "type": "boolean",
          "default": false
        },
        "dependsOn": {
          "type": "object",
          "propertyNames": {
            "$ref": "#/$defs/name"
          },
          "additionalProperties": {
            "enum": ["started", "ready", "completed"]
          }
        },
        "env": {
          "$ref": "#/$defs/environment"
        },
        "secretEnv": {
          "type": "object",
          "propertyNames": {
            "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
          },
          "additionalProperties": {
            "type": "string",
            "pattern": "^keychain://[A-Za-z0-9._:@-]+/[A-Za-z0-9._:@-]+$"
          }
        },
        "labels": {
          "type": "object",
          "maxProperties": 256,
          "propertyNames": {
            "maxLength": 128,
            "pattern": "^(?!dev\\.hostwright\\.).+$"
          },
          "additionalProperties": {
            "type": "string",
            "maxLength": 4096
          }
        },
        "ports": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[0-9]{1,5}:[0-9]{1,5}$"
          }
        },
        "volumes": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^(?!/+(?:\\./*)*:)(?![^:]*(?:^|/)\\.\\.(?:/|:)).+:/[^:]+(:ro|:rw)?$"
          }
        },
        "health": {
          "$ref": "#/$defs/health",
          "deprecated": true
        },
        "probes": {
          "$ref": "#/$defs/probes"
        },
        "restart": {
          "$ref": "#/$defs/restart"
        },
        "update": {
          "$ref": "#/$defs/update"
        },
        "hooks": {
          "$ref": "#/$defs/hooks"
        },
        "rosetta": {
          "type": "boolean",
          "default": false
        },
        "virtualization": {
          "type": "boolean",
          "default": false
        },
        "readOnlyRootFilesystem": {
          "type": "boolean",
          "default": false
        },
        "shmSize": {
          "$ref": "#/$defs/size"
        }
      }
    },
    "platform": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "os": {
          "const": "linux",
          "default": "linux"
        },
        "architecture": {
          "enum": ["arm64", "amd64"],
          "default": "arm64"
        }
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cpus": {
          "type": "integer",
          "minimum": 1
        },
        "memory": {
          "$ref": "#/$defs/size"
        }
      }
    },
    "environment": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "additionalProperties": {
        "type": "string",
        "maxLength": 16384
      }
    },
    "health": {
      "type": "object",
      "required": ["command"],
      "additionalProperties": false,
      "properties": {
        "command": {
          "$ref": "#/$defs/stringArray"
        },
        "interval": {
          "type": "string",
          "pattern": "^[1-9][0-9]*s$"
        }
      }
    },
    "probes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "startup": {
          "$ref": "#/$defs/probe"
        },
        "readiness": {
          "$ref": "#/$defs/probe"
        },
        "liveness": {
          "$ref": "#/$defs/probe"
        }
      }
    },
    "probe": {
      "type": "object",
      "additionalProperties": false,
      "oneOf": [
        {
          "required": ["exec"]
        },
        {
          "required": ["http"]
        },
        {
          "required": ["tcp"]
        }
      ],
      "properties": {
        "exec": {
          "$ref": "#/$defs/stringArray"
        },
        "http": {
          "type": "object",
          "required": ["port"],
          "additionalProperties": false,
          "properties": {
            "port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            },
            "path": {
              "type": "string",
              "pattern": "^/"
            }
          }
        },
        "tcp": {
          "type": "object",
          "required": ["port"],
          "additionalProperties": false,
          "properties": {
            "port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            }
          }
        },
        "startPeriod": {
          "$ref": "#/$defs/duration"
        },
        "interval": {
          "$ref": "#/$defs/duration"
        },
        "timeout": {
          "$ref": "#/$defs/duration"
        },
        "successThreshold": {
          "type": "integer",
          "minimum": 1
        },
        "failureThreshold": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "restart": {
      "type": "object",
      "required": ["policy"],
      "additionalProperties": false,
      "properties": {
        "policy": {
          "enum": ["no", "on-failure", "unless-stopped"]
        }
      }
    },
    "update": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "strategy": {
          "enum": ["rolling", "recreate"],
          "default": "rolling"
        },
        "maxSurge": {
          "type": "integer",
          "minimum": 0,
          "default": 1
        },
        "maxUnavailable": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "progressDeadline": {
          "type": "string",
          "pattern": "^[1-9][0-9]*s$",
          "default": "300s"
        }
      }
    },
    "hooks": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "postStart": {
          "$ref": "#/$defs/hook"
        },
        "preStop": {
          "$ref": "#/$defs/hook"
        }
      }
    },
    "hook": {
      "type": "object",
      "required": ["exec"],
      "additionalProperties": false,
      "properties": {
        "exec": {
          "$ref": "#/$defs/stringArray"
        }
      }
    }
  }
}
