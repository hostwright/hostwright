{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hostwright.dev/schemas/hostwright-yaml.schema.json",
  "title": "Hostwright Manifest",
  "description": "Hostwright manifest shape. The Swift parser supports a restricted Hostwright subset, not general YAML.",
  "type": "object",
  "required": ["project", "services"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "const": 1,
      "description": "Optional in legacy alpha manifests; when present, only manifest version 1 is supported."
    },
    "project": {
      "type": "string",
      "pattern": "^[a-z0-9]([a-z0-9-]{0,61}[a-z0-9])?$"
    },
    "services": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/service"
      }
    }
  },
  "$defs": {
    "service": {
      "type": "object",
      "required": ["image"],
      "additionalProperties": false,
      "properties": {
        "image": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[^-\\s][^\\s]*$"
        },
        "command": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[^-].*$"
          }
        },
        "env": {
          "type": "object",
          "propertyNames": {
            "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "secretEnv": {
          "type": "object",
          "propertyNames": {
            "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
          },
          "additionalProperties": {
            "type": "string",
            "pattern": "^keychain://[A-Za-z0-9._:@-]+/[A-Za-z0-9._:@-]+$"
          }
        },
        "ports": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[0-9]{1,5}:[0-9]{1,5}$"
          }
        },
        "volumes": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^(?!/+(?:\\./*)*:)(?![^:]*(?:^|/)\\.\\.(?:/|:)).+:/[^:]+(:ro|:rw)?$"
          }
        },
        "health": {
          "$ref": "#/$defs/health"
        },
        "restart": {
          "$ref": "#/$defs/restart"
        }
      }
    },
    "health": {
      "type": "object",
      "required": ["command"],
      "additionalProperties": false,
      "properties": {
        "command": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "interval": {
          "type": "string",
          "pattern": "^[1-9][0-9]*s$"
        }
      }
    },
    "restart": {
      "type": "object",
      "required": ["policy"],
      "additionalProperties": false,
      "properties": {
        "policy": {
          "enum": ["no", "on-failure", "unless-stopped"]
        }
      }
    }
  }
}
